module fifo_top_rx565 (
  Data,
  Reset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Almost_Empty,
  Almost_Full,
  Q,
  Empty,
  Full
)
;
input [15:0] Data;
input Reset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output Almost_Empty;
output Almost_Full;
output [15:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.fifo_top_rx565  fifo_inst (
    .Reset(Reset),
    .RdClk(RdClk),
    .WrClk(WrClk),
