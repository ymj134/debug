`pragma protect end_protected
module Uart_to_Bus_Top (
  rst_n_i,
  clk_i,
  apb0_addr_o,
  apb0_sel_o,
  apb0_ena_o,
  apb0_wr_o,
  apb0_rdata_i,
  apb0_wdata_o,
  apb0_rdy_i,
  apb0_strb_o,
  uart_rx_led_o,
  uart_tx_led_o,
  uart_rx_i,
  uart_tx_o
)
;
input rst_n_i;
input clk_i;
output [17:0] apb0_addr_o;
output apb0_sel_o;
output apb0_ena_o;
output apb0_wr_o;
input [31:0] apb0_rdata_i;
output [31:0] apb0_wdata_o;
input apb0_rdy_i;
output [3:0] apb0_strb_o;
output uart_rx_led_o;
output uart_tx_led_o;
input uart_rx_i;
output uart_tx_o;
wire VCC;
wire GND;
  \~uart_bus_core.Uart_to_Bus_Top  uart_bus_core (
    .clk_i(clk_i),
    .apb0_rdy_i(apb0_rdy_i),
    .rst_n_i(rst_n_i),
    .uart_rx_i(uart_rx_i),
    .apb0_rdata_i(apb0_rdata_i[31:0]),
    .apb0_ena_o(apb0_ena_o),
    .apb0_sel_o(apb0_sel_o),
    .apb0_wr_o(apb0_wr_o),
    .uart_rx_led_o(uart_rx_led_o),
    .uart_tx_o(uart_tx_o),
    .uart_tx_led_o(uart_tx_led_o),
    .apb0_wdata_o(apb0_wdata_o[31:0]),
    .apb0_addr_o(apb0_addr_o[9:2])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
assign apb0_addr_o[0] = GND;
assign apb0_addr_o[1] = GND;
assign apb0_addr_o[10] = GND;
assign apb0_addr_o[11] = GND;
assign apb0_addr_o[12] = GND;
assign apb0_addr_o[13] = GND;
assign apb0_addr_o[14] = GND;
assign apb0_addr_o[15] = GND;
assign apb0_addr_o[16] = GND;
assign apb0_addr_o[17] = GND;
assign apb0_strb_o[0] = apb0_sel_o;
assign apb0_strb_o[1] = apb0_sel_o;
assign apb0_strb_o[2] = apb0_sel_o;
assign apb0_strb_o[3] = apb0_sel_o;
endmodule /* Uart_to_Bus_Top */
