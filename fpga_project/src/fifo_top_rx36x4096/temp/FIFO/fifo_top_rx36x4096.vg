module fifo_top_rx36x4096 (
  Data,
  Reset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Almost_Empty,
  Almost_Full,
  Q,
  Empty,
  Full
)
;
input [35:0] Data;
input Reset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output Almost_Empty;
output Almost_Full;
output [35:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.fifo_top_rx36x4096  fifo_inst (
    .Reset(Reset),
    .RdClk(RdClk),
    .WrClk(WrClk),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[35:0]),
    .Empty(Empty),
    .Full(Full),
    .Almost_Empty(Almost_Empty),
    .Almost_Full(Almost_Full),
    .Q(Q[35:0])
);
