`pragma protect end_protected
module I2C_MASTER_Top (
  I_CLK,
  I_RESETN,
  I_TX_EN,
  I_WADDR,
  I_WDATA,
  I_RX_EN,
  I_RADDR,
  O_RDATA,
  O_IIC_INT,
  SCL,
  SDA
)
;
input I_CLK;
input I_RESETN;
input I_TX_EN;
input [2:0] I_WADDR;
input [7:0] I_WDATA;
input I_RX_EN;
input [2:0] I_RADDR;
output [7:0] O_RDATA;
output O_IIC_INT;
inout SCL;
inout SDA;
wire SCL_in;
wire SDA_in;
wire scl_padoen_o;
wire sda_padoen_o;
wire VCC;
wire GND;
  IOBUF SCL_iobuf (
    .O(SCL_in),
    .IO(SCL),
    .I(GND),
    .OEN(scl_padoen_o) 
);
  IOBUF SDA_iobuf (
    .O(SDA_in),
    .IO(SDA),
    .I(GND),
    .OEN(sda_padoen_o) 
);
  \~i2c_master.I2C_MASTER_Top  u_i2c_master (
    .I_CLK(I_CLK),
    .I_RX_EN(I_RX_EN),
    .I_TX_EN(I_TX_EN),
    .I_RESETN(I_RESETN),
    .SCL_in(SCL_in),
    .SDA_in(SDA_in),
    .I_WDATA(I_WDATA[7:0]),
    .I_RADDR(I_RADDR[2:0]),
    .I_WADDR(I_WADDR[2:0]),
    .O_IIC_INT(O_IIC_INT),
    .scl_padoen_o(scl_padoen_o),
    .sda_padoen_o(sda_padoen_o),
    .O_RDATA(O_RDATA[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* I2C_MASTER_Top */
